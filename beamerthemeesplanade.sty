  % Text Nodes on the pages
     \node[anchor=south west, white, text width=0.54*\paperwidth] (author) at (0.05*\paperwidth, 0.05*\paperwidth) {\fontsize{10}{12}\selectfont\bfseries\insertauthor};
    \node[anchor=west, white, text width=0.54*\paperwidth, above=0.08*\paperheight of author] (date) {\fontsize{10}{12}\selectfont\itshape\insertdate\vphantom{Hg}};
      \node[anchor=west, white, text width=0.54*\paperwidth, above=1.2em of date, align=flush left] (subtitle) {\fontsize{12}{14}\selectfont\itshape\insertsubtitle};
      \node[anchor=west, white, text width=0.54*\paperwidth, above=0.75em of subtitle, align=flush left] (title) {\fontsize{17.28}{22}\selectfont\itshape\inserttitle\vphantom{Hg}};
