% Part overrides — split by concern.
% Save original \part before any patching so that the wrappers below can
% delegate back to it without re-triggering any of the hooks.
\let\origpart\part

% Initialise the plain-text part title (used by section-page frametitle).
% \parttitle stores the short-title text without Beamer's hyperlink wrapper.
% https://tex.stackexchange.com/a/13392
\newcommand{\parttitle}{}

% Flag: true if \part was called at least once in this document.
% Used to suppress part numbers on section pages in part-free decks.
% Defines \esplanade@ifparts{<true>}{<false>} for use in templates.
\ExplSyntaxOn
\bool_new:N \g_espl_parts_used_bool
\AddToHook{cmd/part/before}{\bool_gset_true:N \g_espl_parts_used_bool}
\NewDocumentCommand{\esplanade@ifparts}{mm}{%
  \bool_if:NTF \g_espl_parts_used_bool {#1} {#2}%
}
\ExplSyntaxOff

% Reset section numbering at the start of each new part.
% https://tex.stackexchange.com/a/65661
\AddToHook{cmd/part/before}{%
  \beamer@tocsectionnumber=0\relax
  \setcounter{section}{0}%
}

% Store the plain-text part title on each \part call.
\RenewDocumentCommand{\part}{o m}{%
  \IfNoValueTF{#1}%
    {\renewcommand*\parttitle{#2}\origpart{#2}}%
    {\renewcommand*\parttitle{#1}\origpart[#1]{#2}}%
}

% Patch the partpage command to ensure it is in plain format when used outside a frame
\patchcmd{\partpage}%
    {\usebeamertemplate*{part page}}%
    {\ifbeamer@inframe\usebeamertemplate*{part page}\else\frame[plain]{\usebeamertemplate*{part page}}\fi}%
    {}{\errmessage{failed to patch partpage command}}%


% Partpages - showing a modified version of the title screen again
\setbeamertemplate{part page}{%
\begin{tikzpicture}[overlay, remember picture, shift={(current page.south west)}]
