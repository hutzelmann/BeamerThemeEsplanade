% Beamer Theme Esplanade
% Version: 0.0.1
%
% Based on the templates for PowerPoint from MyTHI
% https://mythi.de/index.php?kc=20&pid=pov&mfid=189&otree=1

% TODO: Hide colors when printing, e.g. https://ctan.org/pkg/ocgx2

% TODO: Proper setup for continuing pages and set it up for sectionpages

\usepackage{tikz}
\usepgflibrary{shadings}
\usetikzlibrary{positioning}


% Information for the beamer package
\institute{Technische Hochschule Ingolstadt}

% Initialize colors
\definecolor{THIblau}{HTML}{005A9B}
\definecolor{THIinfo}{HTML}{D7D700}
\definecolor{THIwing}{HTML}{F08200}
\definecolor{THIzaf}{HTML}{007382}
\definecolor{THIelin}{HTML}{96BE00}
\definecolor{THIbusi}{HTML}{E6320F}
\definecolor{THIiaw}{HTML}{009BCD}
\definecolor{THImach}{HTML}{009664}
\definecolor{THIninf}{HTML}{871932}

% Option parsing logic

\usepackage{expl3}
\ExplSyntaxOn
\bool_new:N \l__esplanade_noitalictitles_bool
\DeclareOptionBeamer{faculty}[generic]{%
   \str_case:nnF {#1}
      {
         {generic} {\colorlet{THIfaculty}{THIblau}}
         {b}   {\colorlet{THIfaculty}{THIbusi}}
         {e}   {\colorlet{THIfaculty}{THIelin}}
         {i}   {\colorlet{THIfaculty}{THIinfo}}
         {iaw} {\colorlet{THIfaculty}{THIiaw}}
         {m}   {\colorlet{THIfaculty}{THImach}}
         {ni}  {\colorlet{THIfaculty}{THIninf}}
         {tcw} {\colorlet{THIfaculty}{THIiaw}}
         {w}   {\colorlet{THIfaculty}{THIwing}}
         {zaf} {\colorlet{THIfaculty}{THIzaf}}
      }
      {
         \msg_new:nnn {beamerthemeesplanade} {unknown-faculty}
            { Unknown~faculty~option~'#1';~using~generic~color. }
         \msg_warning:nnn {beamerthemeesplanade} {unknown-faculty} {#1}
         \colorlet{THIfaculty}{THIblau}
      }
}
\ExecuteOptionsBeamer{faculty=generic}
\DeclareOptionBeamer{institute}[none]{%
   \str_case:nnF {#1}
      {
         {none} {}
         {car}  {}
         {aim}  {}
      }
      {
         \msg_new:nnn {beamerthemeesplanade} {unknown-institute}
            { Unknown~institute~option~'#1';~using~generic~logos. }
         \msg_warning:nnn {beamerthemeesplanade} {unknown-institute} {#1}
      }
}
\ExecuteOptionsBeamer{institute=none}
\DeclareOptionBeamer{noitalictitles}{\bool_set_true:N \l__esplanade_noitalictitles_bool}
\ProcessOptionsBeamer
\ExplSyntaxOff


