% Make frame title italic (unless noitalictitles option was given)
\ExplSyntaxOn
\bool_if:NF \l__esplanade_noitalictitles_bool {
   \setbeamerfont{frametitle}{series=\itshape}
   \setbeamerfont{framesubtitle}{series=\itshape}
}
\ExplSyntaxOff

% Make math look like latex math
\usefonttheme[onlymath]{serif}

\providecommand{\GeneralZeroBackground}{
 \begin{scope}
  % Generic Background without any images
  % TODO: Add some small overlap beyond the paper?

  % Cut any overlap over the edges
  \clip (0,0) rectangle (\paperwidth, \paperheight);
  % Rotated rectangle with two blue colors shading
  \draw[white,very thin, top color=THIblau, bottom color=THIblau!50!THIiaw, shading angle=90-10, rotate around={-10:(0.65*\paperwidth, 0.65*\paperheight)}] (0.65*\paperwidth, 0.65*\paperheight) rectangle (-0.05*\paperwidth, -0.2*\paperheight);
  % The logo in the top aligned to the square
  \node[anchor=east,inner sep=0pt,outer sep=0pt,scale=0.26/10cm*\paperwidth] (logo) at (0.95*\paperwidth, 0.675*\paperheight) {\usebox\THILogoWithText};
  % Title graphic in the bottom right corner
  \node[anchor=south east, inner sep=0pt, outer sep=0pt] (titlegraphic) at (0.95*\paperwidth, 0.1*\paperheight) {\usebeamertemplate{titlegraphic}};
 \end{scope}
}

% Patching the maketitle command to ensure it is always plain format
\patchcmd{\maketitle}%
    {\ifbeamer@inframe\titlepage\else\frame{\titlepage}\fi}%
    {\ifbeamer@inframe\titlepage\else\frame[plain]{\titlepage}\fi}%
    {}{\errmessage{failed to patch maketitle command}}%

% Patching the maketitle command to ensure it is in plain format when used outside a frame
\patchcmd{\titlepage}%
    {\usebeamertemplate*{title page}}%
    {\ifbeamer@inframe\usebeamertemplate*{title page}\else\frame[plain]{\usebeamertemplate*{title page}}\fi}%
    {}{\errmessage{failed to patch titlepage command}}%

\setbeamertemplate{title page}{%
